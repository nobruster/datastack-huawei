{
  "realm": "datastack",
  "enabled": true,
  "sslRequired": "none",
  "loginTheme": "keycloak",
  "roles": {
    "realm": [
      {
        "name": "user"
      },
      {
        "name": "superset_admin",
        "description": "Mapeada para o role Admin do Superset via AUTH_ROLES_MAPPING (superset_config.py)"
      },
      {
        "name": "airflow_admin",
        "description": "Mapeada para o role Admin do Airflow via AUTH_ROLES_MAPPING (config/airflow/webserver_config.py)"
      }
    ]
  },
  "clients": [
    {
      "clientId": "oauth2-proxy",
      "name": "oauth2-proxy (Traefik forward-auth)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "secret": "oauth2-proxy-secret-CHANGE-ME",
      "redirectUris": [
        "https://*.<eip>.sslip.io/oauth2/callback",
        "https://seaweedfs.<eip>.sslip.io/oauth2/callback",
        "https://spark.<eip>.sslip.io/oauth2/callback",
        "https://spark-history.<eip>.sslip.io/oauth2/callback",
        "https://seaweedfs-filer.<eip>.sslip.io/oauth2/callback",
        "https://seaweedfs-master.<eip>.sslip.io/oauth2/callback",
        "https://swarmpit.<eip>.sslip.io/oauth2/callback",
        "https://traefik.<eip>.sslip.io/oauth2/callback"
      ],
      "webOrigins": [
        "+"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ]
    },
    {
      "clientId": "trino",
      "name": "Trino Coordinator",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "secret": "trino-oidc-secret-CHANGE-ME",
      "redirectUris": [
        "https://trino.<eip>.sslip.io/oauth2/callback"
      ],
      "webOrigins": [
        "https://trino.<eip>.sslip.io"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ],
      "protocolMappers": [
        {
          "name": "trino-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "trino",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "jupyterhub",
      "name": "JupyterHub",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "secret": "jupyterhub-oidc-secret-CHANGE-ME",
      "redirectUris": [
        "https://jupyter.<eip>.sslip.io/hub/oauth_callback"
      ],
      "webOrigins": [
        "https://jupyter.<eip>.sslip.io"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ]
    },
    {
      "clientId": "superset",
      "name": "Apache Superset",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "secret": "superset-oidc-secret-CHANGE-ME",
      "redirectUris": [
        "https://superset.<eip>.sslip.io/oauth-authorized/keycloak"
      ],
      "webOrigins": [
        "https://superset.<eip>.sslip.io"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "airflow",
      "name": "Apache Airflow",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "secret": "airflow-oidc-secret-CHANGE-ME",
      "redirectUris": [
        "https://airflow.<eip>.sslip.io/auth/oauth-authorized/keycloak"
      ],
      "webOrigins": [
        "https://airflow.<eip>.sslip.io"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "portainer",
      "name": "Portainer",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "secret": "portainer-secret-CHANGE-ME",
      "redirectUris": [
        "https://portainer.<eip>.sslip.io",
        "https://portainer.<eip>.sslip.io/*"
      ],
      "webOrigins": [
        "https://portainer.<eip>.sslip.io"
      ],
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@datastack.local",
      "firstName": "Admin",
      "lastName": "Datastack",
      "credentials": [
        {
          "type": "password",
          "value": "datastack-user-password-CHANGE-ME",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "superset_admin",
        "airflow_admin"
      ]
    },
    {
      "username": "superadmin",
      "enabled": true,
      "emailVerified": true,
      "email": "nobruster@gmail.com",
      "firstName": "Super",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "datastack-user-password-CHANGE-ME",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "superset_admin",
        "airflow_admin"
      ]
    }
  ]
}
